import { test, expect } from '@playwright/test';

// @smoke
test.describe('items CRUD', () => {
  test('create item', async ({ request }) => {
    const res = await request.post('/items', { data: { name: 'test-item' } });
    expect(res.status()).toBe(201);
    const body = await res.json();
    expect(body.id).toBeTruthy();
    expect(body.name).toBe('test-item');
  });

  test('list items', async ({ request }) => {
    const res = await request.get('/items');
    expect(res.ok()).toBeTruthy();
    const body = await res.json();
    expect(Array.isArray(body)).toBe(true);
  });

  test('update item', async ({ request }) => {
    const create = await request.post('/items', { data: { name: 'to-update' } });
    const { id } = await create.json();
    const res = await request.put(`/items/${id}`, { data: { name: 'updated' } });
    expect(res.ok()).toBeTruthy();
    const body = await res.json();
    expect(body.name).toBe('updated');
  });

  test('delete item', async ({ request }) => {
    const create = await request.post('/items', { data: { name: 'to-delete' } });
    const { id } = await create.json();
    const res = await request.delete(`/items/${id}`);
    expect(res.status()).toBe(204);
  });
});
